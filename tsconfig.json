{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "rootDir": "./",
    "moduleResolution": "nodenext",
    "outDir": "./dist/",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@root/*": ["./src/*"],
      "@entidades": ["./src/entidades"],
    }
  },
  "ts-node": {
    "transpileOnly": true
  }
}